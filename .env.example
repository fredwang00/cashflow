# Copy to .env and fill in your values (never commit .env)

# LLM endpoint — required. Must be an OpenAI-compatible chat/completions
# endpoint OR the native Anthropic /v1/messages endpoint.
# The response format is auto-detected.

# Anthropic API (native format)
CASHFLOW_LLM_URL=https://api.anthropic.com/v1/messages
CASHFLOW_LLM_KEY=your-anthropic-key
CASHFLOW_LLM_KEY_HEADER=x-api-key
CASHFLOW_LLM_MODEL=claude-sonnet-4-5-20250929

# OpenAI
# CASHFLOW_LLM_URL=https://api.openai.com/v1/chat/completions
# CASHFLOW_LLM_KEY=your-openai-key
# CASHFLOW_LLM_KEY_HEADER=Authorization  # set value to "Bearer your-key"
# CASHFLOW_LLM_MODEL=gpt-4o-mini

# Local model via Ollama (fully offline, no key needed)
# CASHFLOW_LLM_URL=http://localhost:11434/v1/chat/completions
# CASHFLOW_LLM_KEY=ollama
# CASHFLOW_LLM_KEY_HEADER=apikey
# CASHFLOW_LLM_MODEL=llama3.2

# Local model via vLLM
# CASHFLOW_LLM_URL=http://localhost:8000/v1/chat/completions
# CASHFLOW_LLM_KEY=vllm
# CASHFLOW_LLM_KEY_HEADER=apikey
# CASHFLOW_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
