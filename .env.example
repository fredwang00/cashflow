# Copy to .env and fill in your values (never commit .env)

# LLM endpoint for transaction categorization
# Defaults to Anthropic API if not set
CASHFLOW_LLM_URL=https://api.anthropic.com/v1/messages

# Your API key
CASHFLOW_LLM_KEY=your-key-here

# Model to use (default: claude-sonnet-4-5-20250929)
CASHFLOW_LLM_MODEL=claude-sonnet-4-5-20250929
